{
  "name": "@org/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "prepare": "command -v husky >/dev/null 2>&1 && husky || true",
    "build": "npm --workspace @org/web run build",
    "db:generate": "pnpm --filter @org/db run db:generate",
    "db:migrate": "pnpm --filter @org/db run db:migrate",
    "db:push": "pnpm --filter @org/db run db:push",
    "db:pull": "pnpm --filter @org/db run db:pull",
    "db:seed": "pnpm --filter @org/db run db:seed",
    "db:backfill:clerk-users": "pnpm --filter @org/db run db:backfill:clerk-users",
    "db:seed:photos": "pnpm --filter @org/db run db:seed:photos",
    "db:studio": "pnpm --filter @org/db run db:studio",
    "lint": "nx run-many -t lint --all",
    "lint:fix": "nx run-many -t lint --all -- --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "test": "nx run-many -t test --all"
  },
  "private": true,
  "devDependencies": {
    "@babel/runtime": "~7.27.6",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.24.0",
    "@expo/cli": "~54.0.16",
    "@next/eslint-plugin-next": "^16.1.6",
    "@nx/devkit": "22.6.5",
    "@nx/eslint": "^22.6.5",
    "@nx/eslint-plugin": "^22.6.5",
    "@nx/expo": "22.6.5",
    "@nx/jest": "22.6.5",
    "@nx/js": "22.6.5",
    "@nx/playwright": "22.6.5",
    "@playwright/test": "^1.36.0",
    "@swc-node/register": "1.11.1",
    "@swc/cli": "~0.8.0",
    "@swc/core": "1.15.8",
    "@swc/helpers": "0.5.18",
    "@testing-library/dom": "10.4.0",
    "@testing-library/react": "16.3.0",
    "@testing-library/react-native": "~13.2.0",
    "@types/jest": "^30.0.0",
    "@types/node": "20.19.9",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "10.4.13",
    "babel-jest": "^30.0.2",
    "babel-preset-expo": "~55.0.8",
    "eslint": "^9.24.0",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-playwright": "^1.6.2",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "jest": "^30.0.2",
    "jest-environment-jsdom": "^30.0.2",
    "jest-expo": "~54.0.13",
    "jest-util": "^30.0.2",
    "metro-config": "~0.83.0",
    "metro-resolver": "~0.83.0",
    "nx": "22.6.5",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.58.2"
  },
  "dependencies": {
    "@nx/next": "^22.6.5",
    "next": "~16.1.6",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "packageManager": "pnpm@9.12.0",
  "pnpm": {
    "patchedDependencies": {
      "react-native-css-interop": "patches/react-native-css-interop.patch"
    }
  }
}
