{
  "name": "@org/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "db:generate": "drizzle-kit generate --config drizzle.config.mjs",
    "db:migrate": "drizzle-kit migrate --config drizzle.config.mjs",
    "db:push": "drizzle-kit push --config drizzle.config.mjs",
    "db:pull": "drizzle-kit pull --config drizzle.config.mjs",
    "db:studio": "drizzle-kit studio --config drizzle.config.mjs",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:backfill:clerk-users": "tsx src/scripts/backfill-clerk-users.ts",
    "db:seed:photos": "tsx src/scripts/seed-home-photos.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@clerk/backend": "^3.2.13",
    "drizzle-kit": "^0.31.10",
    "dotenv": "^16.4.7",
    "tsx": "^4.21.0"
  }
}
